  <!-- ░░ SCRIPTS ░░ -->
  <script>
    /* Sidebar visibility */
    function checkWidth() {
      var s = document.getElementById('sidebar');
      if (s) s.style.display = window.innerWidth >= 1024 ? 'flex' : 'none';
    }
    checkWidth();
    window.addEventListener('resize', checkWidth);

    /* Coming soon tooltip */
    function showComingSoon(el) {
      var tip = document.getElementById('soon-tip');
      tip.style.opacity = '1';
      setTimeout(function() { tip.style.opacity = '0'; }, 1800);
    }

    /* Scroll reveal */
    var revealObserver = new IntersectionObserver(function(entries) {
      entries.forEach(function(e) {
        if (e.isIntersecting) {
          e.target.style.opacity = '1';
          e.target.style.transform = 'translateY(0)';
          revealObserver.unobserve(e.target);
        }
      });
    }, { threshold: 0, rootMargin: '0px 0px -40px 0px' });

    document.querySelectorAll('.reveal').forEach(function(el, i) {
      el.style.transition = 'opacity 0.85s cubic-bezier(0.16,1,0.3,1) ' + (i * 0.1) + 's, transform 0.85s cubic-bezier(0.16,1,0.3,1) ' + (i * 0.1) + 's';
      revealObserver.observe(el);
    });

    /* Discord real-time member count */
    async function fetchDiscord() {
      try {
        var r = await fetch('https://discord.com/api/guilds/1452712108868370571/widget.json');
        var d = await r.json();
        if (d && d.presence_count) {
          document.getElementById('member-badge').textContent = d.presence_count.toLocaleString() + '+ ONLINE NOW';
          document.getElementById('stats-members').textContent = d.presence_count.toLocaleString() + '+';
        } else {
          document.getElementById('member-badge').textContent = '1,000+ ACTIVE MEMBERS';
        }
      } catch(e) {
        document.getElementById('member-badge').textContent = '1,000+ ACTIVE MEMBERS';
      }
    }
    fetchDiscord();
    setInterval(fetchDiscord, 60000);
  </script>

