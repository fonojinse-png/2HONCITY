  <link href="https://fonts.googleapis.com/css2?family=Prompt:wght@300;400;500;600&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Prompt', sans-serif;
      background: #efefec;
      color: #18181b;
      overflow-x: hidden;
      min-height: 100vh;
    }

    /* ── Glass panels ─── */
    .g-light {
      background: rgba(255,255,255,0.38);
      backdrop-filter: blur(24px) saturate(200%) brightness(106%);
      -webkit-backdrop-filter: blur(24px) saturate(200%) brightness(106%);
      border-top:    1.5px solid rgba(255,255,255,0.98);
      border-left:   1px solid rgba(255,255,255,0.72);
      border-right:  1px solid rgba(255,255,255,0.52);
      border-bottom: 1px solid rgba(255,255,255,0.20);
      box-shadow:
        0 2.5px 0 0 rgba(255,255,255,0.90) inset,
        0 -1px 0 0 rgba(0,0,0,0.03) inset,
        0 1px 0 0 rgba(255,255,255,0.60) inset,
        0 12px 48px rgba(0,0,0,0.08),
        0 2px 6px rgba(0,0,0,0.04);
      will-change: transform;
    }
    .g-dark {
      background: rgba(14,14,16,0.88);
      backdrop-filter: blur(18px) saturate(160%);
      -webkit-backdrop-filter: blur(18px) saturate(160%);
      border-top:    1.5px solid rgba(255,255,255,0.18);
      border-left:   1px solid rgba(255,255,255,0.10);
      border-right:  1px solid rgba(255,255,255,0.06);
      border-bottom: 1px solid rgba(255,255,255,0.03);
      box-shadow:
        0 1.5px 0 0 rgba(255,255,255,0.14) inset,
        inset -4px -6px 25px rgba(255,255,255,0.05),
        inset 4px 4px 10px rgba(0,0,0,0.40),
        0 28px 64px rgba(0,0,0,0.32),
        0 4px 16px rgba(0,0,0,0.20);
      will-change: transform;
    }

    /* ── Mint text gradient ─── */
    .text-mint {
      background: linear-gradient(118deg, #0284c7 0%, #059669 55%, #0369a1 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    /* ── Ambient orbs ─── */
    @keyframes drift  { 0%,100%{transform:translate(0,0) scale(1)} 50%{transform:translate(18px,-14px) scale(1.06)} }
    @keyframes drift2 { 0%,100%{transform:translate(0,0) scale(1)} 50%{transform:translate(-12px,16px) scale(0.96)} }
    .orb-a { animation: drift  9s ease-in-out infinite; will-change: transform; contain: layout style; }
    .orb-b { animation: drift2 12s ease-in-out infinite; will-change: transform; contain: layout style; }
    .orb-c { animation: drift  14s ease-in-out infinite reverse; will-change: transform; contain: layout style; }

    /* ── Entrance animations ─── */
    @keyframes fadeUp {
      from { opacity:0; transform:translateY(28px); }
      to   { opacity:1; transform:translateY(0); }
    }
    .anim { opacity:0; animation: fadeUp 0.9s cubic-bezier(0.16,1,0.3,1) forwards; }
    .d1 { animation-delay: 0.08s; }
    .d2 { animation-delay: 0.22s; }
    .d3 { animation-delay: 0.36s; }
    .d4 { animation-delay: 0.50s; }
    .d5 { animation-delay: 0.64s; }

    /* ── Pulse dot ─── */
    @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.3} }
    .dot-pulse { animation: pulse 2.4s ease-in-out infinite; }

    /* ── CTA button ─── */
    .cta { transition: transform 0.22s cubic-bezier(0.34,1.56,0.64,1); cursor:pointer; }
    .cta:hover  { transform: scale(1.04); }
    .cta:active { transform: scale(0.97); }

    /* ── Nav links ─── */
    .nav-a {
      position: relative;
      color: rgba(24,24,27,0.45);
      font-size: 13.5px;
      font-weight: 500;
      text-decoration: none;
      transition: color 0.2s;
      white-space: nowrap;
      cursor: pointer;
    }
    .nav-a::after {
      content:'';
      position:absolute;
      bottom:-3px; left:50%; right:50%;
      height:1.5px;
      background: linear-gradient(90deg,#67e8f9,#86efac);
      border-radius:2px;
      transition: left 0.25s ease, right 0.25s ease;
    }
    .nav-a:hover { color:#18181b; }
    .nav-a:hover::after { left:0; right:0; }

    /* ── Social sidebar buttons ─── */
    .soc-btn {
      width:36px; height:36px;
      border-radius:10px;
      display:flex; align-items:center; justify-content:center;
      transition: transform 0.2s cubic-bezier(0.34,1.56,0.64,1), opacity 0.2s;
      opacity:0.6;
    }
    .soc-btn:hover { transform:scale(1.15); opacity:1; }

    /* ── Secondary link ─── */
    .sec-link {
      font-size:13px; font-weight:500;
      color:rgba(24,24,27,0.35);
      text-decoration:none;
      letter-spacing:0.02em;
      transition:color 0.2s;
    }
    .sec-link:hover { color:#67e8f9; }

    /* ── Scroll reveal ─── */
    .reveal {
      opacity:0;
      transform:translateY(36px);
      contain: layout;
    }

    /* ── Tag pills ─── */
    .tag-blue { padding:6px 16px; border-radius:999px; font-size:12.5px; font-weight:500; background:rgba(14,165,233,0.10); color:#0284c7; }
    .tag-green { padding:6px 16px; border-radius:999px; font-size:12.5px; font-weight:500; background:rgba(16,185,129,0.10); color:#059669; }

    /* ── Stats bar numbers ─── */
    .stat-num { font-size:clamp(32px,4.5vw,52px); font-weight:600; letter-spacing:-0.04em; }
    .stat-label { font-size:12px; font-weight:400; color:rgba(255,255,255,0.45); letter-spacing:0.07em; text-transform:uppercase; }

    /* ── Grid responsive ─── */
    .grid-2 { display:grid; grid-template-columns:1fr 1fr; gap:20px; }
    .grid-3 { display:grid; grid-template-columns:repeat(3,1fr); gap:16px; }

    @media (max-width:700px) {
      .grid-2 { grid-template-columns:1fr; }
      .grid-3 { grid-template-columns:1fr; }
    }
    @media (min-width:701px) and (max-width:960px) {
      .grid-3 { grid-template-columns:1fr 1fr; }
    }
  </style>
</head>
